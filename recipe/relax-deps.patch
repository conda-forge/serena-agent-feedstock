Relax exact dependency pins and remove packages not available on conda-forge.

The upstream pyproject.toml pins all dependencies with ==, which is too strict
for conda packaging. This patch relaxes pins to >= and removes packages that
are either unavailable on conda-forge (dotenv, pywebview, pystray, pythonnet)
or are transitive dependencies that don't need explicit pinning.

--- a/pyproject.toml
+++ b/pyproject.toml
@@ -18,38 +18,23 @@
 ]
 dependencies = [
-  "requests==2.33.0",
-  "pyright==1.1.403",
-  "fortls==3.2.2",
-  "overrides==7.7.0",
-  "python-dotenv==1.2.2",
-  "mcp==1.27.0",
-  "flask==3.1.3", # bumped from 3.1.1 for CVE fix (also fixes werkzeug alert)
-  "sensai-utils==1.5.0",
-  "pydantic==2.12.5",
-  "types-pyyaml==6.0.12.20250516",
-  "pyyaml==6.0.2",
-  "ruamel.yaml==0.18.14",
-  "jinja2==3.1.6",
-  "dotenv==0.9.9",
-  "pathspec==0.12.1",
-  "psutil==7.0.0",
-  "docstring_parser==0.17.0",
-  "joblib==1.5.1",
